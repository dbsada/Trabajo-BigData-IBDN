# ============================================
# PROJECT HOME
# ============================================
PROJECT_HOME=xxx        # <--- Set your project home directory here
GITHUB_REPO=https://github.com/dbsada/Trabajo-BigData-IBDN

# ============================================
# GOOGLE CLOUD
# ============================================
GCP_PROJECT=xxx         # <--- Set your GCP project ID here
GCP_ZONE=europe-west1-b # <--- Set your GCP zone here
GCP_INSTANCE=bigdata-vm 
GCP_USER=ubuntu

# ============================================
# Credentials
# ============================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# ============================================
# Endpoints
# ============================================
MINIO_ENDPOINT=http://minio:9000
MINIO_LOCAL_ENDPOINT=http://localhost:9000
SPARK_MASTER_URL=spark://spark:7077
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_LOCAL_BOOTSTRAP_SERVERS=localhost:9092
MONGODB_URI=mongodb://mongodb:27017

# ============================================
# Container names
# ============================================
SPARK_CONTAINER=spark
KAFKA_CONTAINER=kafka
MONGODB_CONTAINER=mongodb

# ============================================
# Application config
# ============================================
ICEBERG_CATALOG=lakehouse
ICEBERG_WAREHOUSE=s3a://lakehouse/warehouse/
KAFKA_TOPIC=flight-delay-ml-request
KAFKA_RESPONSE_TOPIC=flight-delay-ml-response
KAFKA_STATUS_TOPIC=flight-delay-ml-status
MONGODB_DATABASE=agile_data_science
MONGODB_DISTANCES_COLLECTION=origin_dest_distances
MONGODB_RESPONSE_COLLECTION=flight_delay_ml_response

# ============================================
# Ports
# ============================================
SPARK_MASTER_UI_PORT=8080
SPARK_MASTER_PORT=7077
FLASK_PORT=5001
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
KAFKA_PORT=9092
MONGODB_PORT=27017
CASSANDRA_PORT=9042
MLFLOW_PORT=5002

# ============================================
# MLflow
# ============================================
MLFLOW_TRACKING_URI=http://mlflow:5000

# ============================================
# Paths
# ============================================
DISTANCES_FILE=data/origin_dest_distances.jsonl
PREDICTION_JAR=/app/flight_prediction/target/scala-2.13/flight_prediction_2.13-0.1.jar
PREDICTION_LOG=logs/flight_prediction_2.13-0.1.jar.log
CHECKPOINT_DIR=/tmp/spark_checkpoint_mongo

# ============================================
# Spark packages (for spark-submit)
# ============================================
SPARK_PACKAGES=org.mongodb.spark:mongo-spark-connector_2.13:10.4.1,org.apache.spark:spark-sql-kafka-0-10_2.13:4.1.1,org.apache.hadoop:hadoop-aws:3.4.1,software.amazon.awssdk:bundle:2.25.70

# ============================================
# Data download URLs
# ============================================
FLIGHT_DELAYS_URL=http://s3.amazonaws.com/agile_data_science/simple_flight_delay_features.jsonl.bz2
ORIGIN_DEST_DISTANCES_URL=http://s3.amazonaws.com/agile_data_science/origin_dest_distances.jsonl
VECTORIZER_URL=http://s3.amazonaws.com/agile_data_science/sklearn_vectorizer.pkl
REGRESSOR_URL=http://s3.amazonaws.com/agile_data_science/sklearn_regressor.pkl

# ============================================
# ML configuration
# ============================================
MODEL_VERSION=5.0
BUCKETIZER_VERSION=2.0
RF_MAX_BINS=4657
RF_MAX_MEMORY_MB=1024

# ============================================
# Flask
# ============================================
RECORDS_PER_PAGE=15
AIRPLANE_RECORDS_PER_PAGE=5
